# ===========================================
# Whisper-Input-Next 环境变量配置模板
# 复制此文件为 .env 并填入您的实际配置
# ===========================================

# ===== 服务平台配置 =====
# 推荐使用双平台配置（我们主要维护的配置）
SERVICE_PLATFORM=openai&local

# ===== 豆包流式 ASR 配置 (推荐) =====
# 获取 API Key: https://console.volcengine.com/ark/region:ark+cn-beijing/tts/speechRecognition
# DOUBAO_APP_KEY=your_app_id_here
# DOUBAO_ACCESS_KEY=your_access_token_here

# ===== 智谱 GLM-ASR 配置 =====
# 获取 API Key: https://open.bigmodel.cn/usercenter/proj-mgmt/apikeys
# 注意: GLM-ASR 音频时长上限 30 秒
GLM_ASR_API_KEY=

# 转录服务选择: "doubao" (默认，流式) / "openai" (批量) / "glm-asr" (智谱)
TRANSCRIPTION_SERVICE=glm-asr

# ===== OpenAI 配置 (可选) =====
# OpenAI GPT-4o transcribe API密钥
# OFFICIAL_OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ===== 本地 Whisper.cpp 配置 =====
# whisper.cpp 可执行文件路径 (需要先安装 whisper.cpp)
WHISPER_CLI_PATH=/path/to/whisper.cpp/build/bin/whisper-cli
# whisper 模型路径 (相对于whisper.cpp根目录)
WHISPER_MODEL_PATH=models/ggml-large-v3.bin

# ===== 键盘快捷键配置 =====
# 转录快捷键 (Super+Space)
TRANSCRIPTIONS_BUTTON= #space
# 翻译快捷键 (与转录按钮组合的修饰键)
TRANSLATIONS_BUTTON= #cmd
# 系统平台 (mac/win/linux)
SYSTEM_PLATFORM=linux

# ===== 功能开关 =====
# 是否转换为简体中文
CONVERT_TO_SIMPLIFIED=false
# 是否自动添加标点符号
ADD_SYMBOL=false
# 是否优化结果
OPTIMIZE_RESULT=false
# 是否启用Kimi润色功能 (已废弃，推荐关闭)
ENABLE_KIMI_POLISH=false
# 自动重试次数（OpenAI/翻译）
AUTO_RETRY_LIMIT=5

# ===== 状态栏图标自定义（可选） =====
# 图标文件支持 PNG/PDF，默认使用 assets/icons/idle.png 等
# STATUS_ICON_IDLE=/path/to/Whisper-Input-Next/Whisper-Input-Next/assets/icons/idle.png
# STATUS_ICON_RECORDING=/path/to/Whisper-Input-Next/Whisper-Input-Next/assets/icons/recording.png
# STATUS_ICON_PROCESSING=/path/to/Whisper-Input-Next/Whisper-Input-Next/assets/icons/transcripting.png

# STATUS_ICON_TEMPLATE=true

# ===== 兼容性配置 (仅作兼容保留) =====
# 以下配置仅作兼容性保留，推荐使用上面的 openai&local 配置

# GROQ 配置 (兼容保留)
# GROQ_API_KEY=your-groq-api-key-here

# SiliconFlow 配置 (兼容保留)
# SILICONFLOW_API_KEY=your-siliconflow-api-key-here

# Kimi 配置 (已废弃)
# KIMI_API_KEY=your-kimi-api-key-here
# KIMI_BASE_URL=https://api.moonshot.cn/v1
HOLD_BUTTON=cmd_r
